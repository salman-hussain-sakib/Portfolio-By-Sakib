            <div
              class="card p-6 text-center group hover:border-purple-500/50 transition-all duration-300 bg-slate-200/40 dark:bg-slate-900/40 backdrop-blur-sm">
              <div
                class="w-10 h-10 rounded-xl bg-purple-500/10 flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform">
                <i class="fas fa-briefcase text-purple-400 text-lg"></i>
              </div>
              <p class="text-slate-900 dark:text-white font-bold text-xl">Completed</p>
