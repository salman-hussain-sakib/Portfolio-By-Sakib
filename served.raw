    <div class="hero-blob w-80 h-80 bg-purple-600 bottom-10 right-0" style="animation-delay:3s"></div>
    <!-- Grid Pattern -->
    <div class="absolute inset-0 opacity-5"
      style="background-image:linear-gradient(rgba(99,102,241,.3) 1px,transparent 1px),linear-gradient(90deg,rgba(99,102,241,.3) 1px,transparent 1px);background-size:60px 60px;">
    </div>

    <div class="max-w-7xl mx-auto px-6 py-20 grid lg:grid-cols-2 gap-16 items-center relative z-10">
      <!-- Left Content -->
      <div class="space-y-8">
