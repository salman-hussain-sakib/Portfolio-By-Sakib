            <i class="fas fa-file-pdf"></i> Download CV
          </a>
        </div>
        <!-- Social Links -->
        <div class="flex items-center gap-3 pt-2">
          <span class="text-slate-500 text-sm">Find me on:</span>
          <a href="https://github.com/salman-hussain-sakib" target="_blank" class="social-btn" title="GitHub"><i
              class="fab fa-github"></i></a>
          <a href="https://www.linkedin.com/in/salmanhussainsakib" target="_blank" class="social-btn" title="LinkedIn"><i
              class="fab fa-linkedin-in"></i></a>
          <a href="https://x.com/sakibsalmanh" target="_blank" class="social-btn" title="X (Twitter)"><i
              class="fab fa-twitter"></i></a>
          <a href="https://www.facebook.com/SAKIB.SALMAN.HUSSAIN" target="_blank" class="social-btn" title="Facebook"><i
              class="fab fa-facebook-f"></i></a>
        </div>
      </div>

      <!-- Right: The Futuristic Neural HUD Interface (Unique & High-Tech) -->
      <div class="flex justify-center lg:justify-end relative lg:translate-x-16 overflow-hidden sm:overflow-visible">
        <div class="relative flex items-center justify-center w-[250px] h-[250px] sm:w-[400px] sm:h-[400px] lg:w-[500px] lg:h-[500px]">

          <!-- Layer 1: Neural Pulse & Grid -->
          <div
            class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_center,rgba(99,102,241,0.15)_0%,transparent_70%)] animate-pulse">
          </div>

          <!-- Layer 2: Rotating HUD Rings (Multiple Speeds) -->
          <div class="absolute inset-0 z-10 opacity-40">
            <svg viewBox="0 0 200 200" class="w-full h-full">
              <!-- Outer Fast Ring -->
              <circle cx="100" cy="100" r="95" fill="none" stroke="#6366f1" stroke-width="0.5" stroke-dasharray="10 20"
                class="animate-[spin_30s_linear_infinite]" />
              <!-- Middle Slow Ring -->
              <circle cx="100" cy="100" r="85" fill="none" stroke="#a855f7" stroke-width="1" stroke-dasharray="80 120"
                class="animate-[spin_60s_linear_infinite_reverse]" />
              <!-- Inner Tech Brackets -->
              <path d="M70 30 A 80 80 0 0 1 130 30 M70 170 A 80 80 0 0 0 130 170" fill="none" stroke="#6366f1"
                stroke-width="2" />
            </svg>
          </div>

          <!-- Layer 3: Laser Scanning Line -->
          <div
            class="absolute w-[80%] h-1 bg-gradient-to-r from-transparent via-indigo-500 to-transparent z-30 blur-[2px] animate-[scan_4s_ease-in-out_infinite]"
            style="top: 20%;"></div>

          <!-- Layer 4: The Profile Image (HD Original with Portal Mask) -->
          <div
            class="circle-glow relative z-20 w-44 h-44 sm:w-80 sm:h-80 lg:w-96 lg:h-96 rounded-full overflow-hidden border-4 border-indigo-500/30 shadow-[0_0_50px_rgba(99,102,241,0.3)] bg-transparent group cursor-pointer transition-all duration-500 hover:shadow-[0_0_80px_rgba(99,102,241,0.6)] hover:border-indigo-400/60"
            style="-webkit-mask-image: radial-gradient(circle at 50% 40%, black 50%, transparent 95%); mask-image: radial-gradient(circle at 50% 40%, black 50%, transparent 95%);">
            <img src="images/profile-professional.jpg" alt="Salman Hussain Sakib"
              class="profile-anim w-full h-full object-cover object-top scale-[1.3] translate-y-4 grayscale-0 dark:grayscale group-hover:grayscale-0 group-hover:scale-[1.35] transition-all duration-700 ease-in-out" />
            <!-- Inner Glow Overlay for Depth -->
            <div class="absolute inset-0 shadow-[inset_0_0_40px_rgba(99,102,241,0.2)] pointer-events-none group-hover:opacity-50 transition-opacity duration-700 rounded-full"></div>
          </div>

          <!-- Layer 5: Data Terminals (Neural Nodes) -->
          <!-- Terminal 1: Problem Solving -->
          <div class="absolute -right-4 sm:-right-12 top-0 sm:top-10 z-40 scale-75 sm:scale-100">
            <div class="flex items-start gap-3">
              <div class="w-px h-16 bg-gradient-to-b from-indigo-500 to-transparent"></div>
              <div class="tech-terminal p-3 border-l-2 border-indigo-500">
                <span class="text-[8px] text-indigo-400 font-mono block mb-1">SYSTEM_METRIC_01</span>
                <p class="text-slate-900 dark:text-white font-black text-xl leading-none font-mono">120<span
                    class="text-indigo-500 text-xs blink">_</span></p>
                <p class="text-slate-500 text-[9px] uppercase tracking-widest mt-1">Systems Architect</p>
              </div>
            </div>
          </div>

          <!-- Terminal 2: Experience -->
          <div class="absolute -left-8 sm:-left-20 top-1/2 -translate-y-1/2 z-40 scale-75 sm:scale-100">
            <div class="flex items-center gap-3">
              <div class="tech-terminal p-3 border-r-2 border-purple-500 text-right">
                <span class="text-[8px] text-purple-400 font-mono block mb-1">CORE_TIME_LOG</span>
                <p class="text-slate-900 dark:text-white font-black text-xl leading-none font-mono">3.0<span
                    class="text-purple-500 text-xs">YRS</span></p>
                <p class="text-slate-500 text-[9px] uppercase tracking-widest mt-1">System Experience</p>
              </div>
              <div class="w-px h-16 bg-gradient-to-b from-purple-500 to-transparent"></div>
            </div>
          </div>

          <!-- Terminal 3: Projects -->
          <div class="absolute right-0 sm:right-4 bottom-0 sm:bottom-4 z-40 scale-75 sm:scale-100">
            <div class="tech-terminal p-3 border-t-2 border-indigo-400">
              <div class="flex justify-between items-center mb-1">
                <span class="text-[8px] text-indigo-400 font-mono">DEP_ACTIVE_TASKS</span>
                <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
              </div>
              <p class="text-slate-900 dark:text-white font-black text-xl leading-none font-mono">150+</p>
              <p class="text-slate-500 text-[9px] uppercase tracking-widest mt-1">Deployments Finished</p>
            </div>
          </div>

        </div>
      </div>

      <!-- Custom Tech UI Styles -->
      <style>
        @keyframes scan {

          0%,
          100% {
            transform: translateY(0);
            opacity: 0;
          }

          50% {
            transform: translateY(350px);
            opacity: 1;
          }
        }

        .blink {
          animation: blinker 1s linear infinite;
        }

        @keyframes blinker {
          50% {
            opacity: 0;
          }
        }

        .tech-terminal {
          background: var(--card-bg);
          border: 1px solid var(--card-border);
          box-shadow: var(--card-shadow);
          min-width: 140px;
          backdrop-filter: blur(8px);
          -webkit-backdrop-filter: blur(8px);
          border-radius: 4px;
        }

        /* Advanced Light Mode Animation */
        @keyframes neural-pulse {
          0%, 100% { 
            transform: scale(1.3) translateY(16px); 
            filter: drop-shadow(0 0 20px rgba(99, 102, 241, 0.2));
          }
          50% { 
            transform: scale(1.32) translateY(8px); 
            filter: drop-shadow(0 0 40px rgba(168, 85, 247, 0.4));
          }
        }

        body:not(.dark) .profile-anim {
          animation: neural-pulse 6s ease-in-out infinite;
        }

        /* Advanced Border Glow Animation */
        @keyframes aurora-border {
          0%, 100% { 
            border-color: rgba(99, 102, 241, 0.4); 
            box-shadow: 0 0 30px rgba(99, 102, 241, 0.3);
          }
          33% { 
            border-color: rgba(168, 85, 247, 0.6); 
            box-shadow: 0 0 50px rgba(168, 85, 247, 0.4);
          }
          66% { 
            border-color: rgba(236, 72, 153, 0.6); 
            box-shadow: 0 0 50px rgba(236, 72, 153, 0.4);
          }
        }

        body:not(.dark) .circle-glow {
          animation: aurora-border 8s linear infinite;
        }
      </style>
    </div>

    <!-- Scroll indicator -->
    <div
      class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-500 animate-bounce">
      <span class="text-xs tracking-widest">SCROLL</span>
      <i class="fas fa-chevron-down"></i>
    </div>
