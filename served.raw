            </div>
            <div
              class="card p-6 text-center group hover:border-pink-500/50 transition-all duration-300 bg-slate-200/40 dark:bg-slate-900/40 backdrop-blur-sm">
              <div
                class="w-10 h-10 rounded-xl bg-pink-500/10 flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform">
                <i class="fas fa-headset text-pink-400 text-lg"></i>
              </div>
              <p class="text-slate-900 dark:text-white font-bold text-xl">Support</p>
              <p class="text-slate-700 dark:text-slate-500 text-xs mt-1 uppercase tracking-tighter">Online 24/7</p>
